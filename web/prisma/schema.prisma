generator client {
    provider = "prisma-client"
    output   = "./generated"
}

datasource db {
    provider = "postgresql"
}

model Session {
    id               String            @id @default(uuid())
    accessToken      String?
    expires          DateTime?
    isOnline         Boolean
    scope            String?
    shop             String
    state            String
    apiKey           String
    createdAt        DateTime          @default(now())
    updatedAt        DateTime          @updatedAt
    onlineAccessInfo OnlineAccessInfo?

    @@map("sessions")
}

model OnlineAccessInfo {
    id                  String          @id @default(uuid())
    sessionId           String?         @unique
    expiresIn           Int
    associatedUserScope String
    createdAt           DateTime        @default(now())
    updatedAt           DateTime        @updatedAt
    associatedUser      AssociatedUser?
    session             Session?        @relation(fields: [sessionId], references: [id])

    @@map("online_access_infos")
}

model AssociatedUser {
    id                 String            @id @default(uuid())
    onlineAccessInfoId String?           @unique
    createdAt          DateTime          @default(now())
    updatedAt          DateTime          @updatedAt
    userId             BigInt
    firstName          String
    lastName           String
    email              String
    accountOwner       Boolean
    locale             String
    collaborator       Boolean
    emailVerified      Boolean
    onlineAccessInfo   OnlineAccessInfo? @relation(fields: [onlineAccessInfoId], references: [id])

    @@map("associated_users")
}

model Bundle {
    id                   String               @id
    shop                 String
    name                 String
    description          String?
    type                 BundleType
    status               BundleStatus         @default(DRAFT)
    mainProductId        String?
    mainVariantId        String?
    isPublished          Boolean              @default(false)
    publishedAt          DateTime?
    buyQuantity          Int?
    getQuantity          Int?
    usesPerOrderLimit    Int?
    minimumItems         Int?
    maximumItems         Int?
    discountType         DiscountType
    discountValue        Float
    minOrderValue        Float?
    maxDiscountAmount    Float?
    volumeTiers          Json?
    allowMixAndMatch     Boolean              @default(false)
    mixAndMatchPrice     Float?
    discountApplication  String?              @default("bundle")
    discountedProductIds String[]             @default([])
    freeShipping         Boolean              @default(false)
    priority             Int                  @default(0)
    priorityType         String               @default("index_based")
    images               String[]
    marketingCopy        String?
    seoTitle             String?
    seoDescription       String?
    views                Int                  @default(0)
    conversions          Int                  @default(0)
    revenue              Float                @default(0)
    startDate            DateTime?
    endDate              DateTime?
    aiOptimized          Boolean              @default(false)
    aiScore              Float?
    createdAt            DateTime             @default(now())
    updatedAt            DateTime             @updatedAt
    deletedAt            DateTime?
    abTests              ABTest[]
    automations          AutomationBundle[]
    analytics            BundleAnalytics[]
    productGroups        BundleProductGroup[]
    bundleProducts       BundleProduct[]
    settings             BundleSettings?
    bundleViews          BundleView[]

    @@unique([shop, name])
    @@index([shop, status, type])
    @@index([shop, createdAt])
    @@index([mainProductId])
    @@index([status, startDate])
    @@index([status, endDate])
    @@map("bundles")
}

model BundleProduct {
    id           String              @id @default(cuid())
    bundleId     String
    productId    String
    variantId    String?
    quantity     Int                 @default(1)
    displayOrder Int                 @default(0)
    role         BundleProductRole   @default(INCLUDED)
    groupId      String?
    customPrice  Float?
    isRequired   Boolean             @default(true)
    minQuantity  Int?
    maxQuantity  Int?
    createdAt    DateTime            @default(now())
    updatedAt    DateTime            @updatedAt
    bundle       Bundle              @relation(fields: [bundleId], references: [id], onDelete: Cascade)
    group        BundleProductGroup? @relation(fields: [groupId], references: [id])

    @@unique([bundleId, productId, variantId, role])
    @@index([bundleId, role])
    @@index([bundleId, displayOrder])
    @@index([productId])
    @@map("bundle_products")
}

model BundleProductGroup {
    id           String          @id @default(cuid())
    bundleId     String
    name         String
    description  String?
    minSelection Int             @default(0)
    maxSelection Int?
    displayOrder Int             @default(0)
    createdAt    DateTime        @default(now())
    updatedAt    DateTime        @updatedAt
    bundle       Bundle          @relation(fields: [bundleId], references: [id], onDelete: Cascade)
    products     BundleProduct[]

    @@index([bundleId])
    @@map("bundle_product_groups")
}

model BundleSettings {
    id             String  @id @default(cuid())
    bundleId       String  @unique
    layout         String  @default("GRID")
    title          String?
    subtitle       String?
    cartButtonText String?

    // Display settings
    showImages        Boolean @default(true)
    showSavingsBadge  Boolean @default(true)
    showPrices        Boolean @default(true)
    showComparePrices Boolean @default(true)
    showSavings       Boolean @default(true)
    showFreeShipping  Boolean @default(true)
    enableHyperLink   Boolean @default(false)
    showQuantity      Boolean @default(true)

    bundle Bundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("bundle_settings")
}

model ABTest {
    id              String       @id @default(cuid())
    shop            String
    name            String
    hypothesis      String?
    type            TestType
    status          TestStatus   @default(DRAFT)
    trafficSplit    Int          @default(50)
    duration        Int          @default(14)
    minSampleSize   Int          @default(100)
    controlBundleId String
    variantConfig   Json
    winner          String?
    significance    Float?
    improvement     Float?
    startedAt       DateTime?
    completedAt     DateTime?
    createdAt       DateTime     @default(now())
    updatedAt       DateTime     @updatedAt
    shopId          String?
    controlBundle   Bundle       @relation(fields: [controlBundleId], references: [id])
    Shop            Shop?        @relation(fields: [shopId], references: [id])
    results         TestResult[]

    @@index([shop, status])
    @@index([shopId])
    @@map("ab_tests")
}

model TestResult {
    id          String   @id @default(cuid())
    testId      String
    variant     String
    date        DateTime @default(now())
    views       Int      @default(0)
    conversions Int      @default(0)
    revenue     Float    @default(0)
    recordedAt  DateTime @default(now())
    updatedAt   DateTime @updatedAt
    test        ABTest   @relation(fields: [testId], references: [id], onDelete: Cascade)

    @@unique([testId, variant, date])
    @@map("test_results")
}

model Automation {
    id            String             @id @default(cuid())
    shop          String
    name          String
    description   String?
    status        AutomationStatus   @default(ACTIVE)
    triggerType   TriggerType
    triggerConfig Json
    conditions    Json
    actions       Json
    triggerCount  Int                @default(0)
    successCount  Int                @default(0)
    errorCount    Int                @default(0)
    lastTriggered DateTime?
    createdAt     DateTime           @default(now())
    updatedAt     DateTime           @updatedAt
    shopId        String?
    bundles       AutomationBundle[]
    logs          AutomationLog[]
    Shop          Shop?              @relation(fields: [shopId], references: [id])

    @@index([shop, status])
    @@index([shopId])
    @@map("automations")
}

model AutomationBundle {
    id           String     @id @default(cuid())
    automationId String
    bundleId     String
    automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
    bundle       Bundle     @relation(fields: [bundleId], references: [id], onDelete: Cascade)

    @@unique([automationId, bundleId])
    @@map("automation_bundles")
}

model AutomationLog {
    id           String     @id @default(cuid())
    automationId String
    event        String
    success      Boolean
    data         Json?
    error        String?
    createdAt    DateTime   @default(now())
    automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

    @@index([automationId, createdAt])
    @@map("automation_logs")
}

model BundleAnalytics {
    id                         String   @id @default(cuid())
    bundleId                   String
    date                       DateTime
    hour                       Int?
    bundleViews                Int      @default(0)
    bundleAddToCarts           Int      @default(0)
    bundlePurchases            Int      @default(0)
    bundleRevenue              Float    @default(0)
    crossSellViews             Int      @default(0)
    crossSellPurchases         Int      @default(0)
    newCustomerPurchases       Int      @default(0)
    returningCustomerPurchases Int      @default(0)
    bundle                     Bundle   @relation(fields: [bundleId], references: [id], onDelete: Restrict)

    @@unique([bundleId, date, hour])
    @@index([bundleId, date])
    @@index([date, bundleId])
    @@map("bundle_analytics")
}

model BundleView {
    id         String   @id @default(cuid())
    bundleId   String
    customerId String?
    sessionId  String?
    date       String
    timestamp  DateTime @default(now())

    bundle Bundle @relation(fields: [bundleId], references: [id], onDelete: Restrict)

    // One view per customer per bundle per day
    @@unique([bundleId, customerId, date], name: "unique_customer_view")
    // One view per session per bundle per day (for anonymous)
    @@unique([bundleId, sessionId, date], name: "unique_session_view")
    @@index([bundleId])
    @@index([customerId])
    @@index([date])
    @@map("bundle_views")
}

model AIInsight {
    id          String        @id @default(cuid())
    shop        String
    type        AIInsightType
    category    String
    title       String
    description String
    confidence  Float
    impact      String
    actionable  Boolean       @default(true)
    actionType  String?
    actionData  Json?
    implemented Boolean       @default(false)
    views       Int           @default(0)
    applied     Int           @default(0)
    improvement Float?
    bundleId    String?
    testId      String?
    createdAt   DateTime      @default(now())
    updatedAt   DateTime      @updatedAt
    expiresAt   DateTime?
    shopId      String?
    Shop        Shop?         @relation(fields: [shopId], references: [id])

    @@index([shop, type, confidence])
    @@index([shopId])
    @@map("ai_insights")
}

model Notification {
    id          String               @id @default(cuid())
    shop        String
    type        NotificationType
    title       String
    message     String
    data        Json?
    read        Boolean              @default(false)
    priority    NotificationPriority @default(NORMAL)
    actionLabel String?
    actionUrl   String?
    createdAt   DateTime             @default(now())
    updatedAt   DateTime             @updatedAt
    expiresAt   DateTime?
    shopId      String?
    Shop        Shop?                @relation(fields: [shopId], references: [id])

    @@index([shop, read, createdAt])
    @@index([shopId])
    @@map("notifications")
}

model AlertRule {
    id              String           @id @default(cuid())
    shop            String
    name            String
    type            NotificationType
    status          AlertRuleStatus  @default(ACTIVE)
    conditions      Json
    threshold       Float?
    comparison      String?
    deliveryMethods Json
    frequency       AlertFrequency   @default(IMMEDIATE)
    triggerCount    Int              @default(0)
    lastTriggered   DateTime?
    createdAt       DateTime         @default(now())
    updatedAt       DateTime         @updatedAt
    shopId          String?
    Shop            Shop?            @relation(fields: [shopId], references: [id])

    @@index([shop, status])
    @@index([shopId])
    @@map("alert_rules")
}

model Shop {
    id                 String     @id @default(cuid())
    domain             String     @unique
    status             ShopStatus @default(ACTIVE)

    metafieldSetupDone Boolean    @default(false)
    discountSetupDone  Boolean    @default(false)

    // Setup tracking
    setupComplete       Boolean   @default(false)
    setupGuideDismissed Boolean   @default(false)
    setupProgress       Json?     @default("{}")
    webhooksRegistered  Boolean   @default(false)
    lastSetupCheck      DateTime?

    // Locales (cached from Shopify shopLocales query)
    locales          Json?
    primaryLocale    String    @default("en")
    localesUpdatedAt DateTime?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    abTests       ABTest[]
    aiInsights    AIInsight[]
    alertRules    AlertRule[]
    appSettings   AppSettings?   @relation("ShopAppSettings")
    automations   Automation[]
    notifications Notification[]
    shopPlan      ShopPlan?      @relation("ShopShopPlan")

    @@index([domain, setupComplete])
    @@map("shops")
}

model AppSettings {
    id     String @id @default(cuid())
    shopId String @unique

    // Defaults
    defaultDiscountType  DiscountType @default(PERCENTAGE)
    defaultDiscountValue Float        @default(10)
    maxBundleProducts    Int          @default(10)
    maxBundlesPerShop    Int          @default(5)
    bundlePriorityType   String       @default("index_based")

    // Cart Behavior Section
    redirectAfterCart     String  @default("cart")
    hidePaymentButtons    Boolean @default(false)
    enableStockValidation Boolean @default(true)
    maxBundlesPerOrder    Int     @default(0)
    showSavingsBanner     Boolean @default(true)
    allowDiscountStacking Boolean @default(false)

    // Privacy Section
    enableAnalytics Boolean @default(true)

    // Labels
    labels Json?

    // Styles
    globalStyles Json?

    // Advanced
    customCssClass String @default("")
    customCss      String @default("")

    // Performance
    cacheTtl       Int     @default(300)
    lazyLoadImages Boolean @default(true)

    // Metadata
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    shop Shop @relation("ShopAppSettings", fields: [shopId], references: [id])

    @@map("app_settings")
}

model WebhookDelivery {
    id          String   @id
    topic       String
    shop        String
    processedAt DateTime @default(now())

    @@index([shop])
    @@index([processedAt])
    @@map("webhook_deliveries")
}

model ShopPlan {
    id               String                     @id @default(cuid())
    shop             String                     @unique
    shopId           String?                    @unique
    shopRef          Shop?                      @relation("ShopShopPlan", fields: [shopId], references: [id])
    plan             PlanName                   @default(FREE)
    status           ShopifySubscriptionStatus?
    billingId        String?                    @unique
    billingInterval  String?
    trialUsed        Boolean                    @default(false)
    trialEndsAt      DateTime?
    currentPeriodEnd DateTime?
    activatedAt      DateTime?
    cancelledAt      DateTime?
    createdAt        DateTime                   @default(now())
    updatedAt        DateTime                   @updatedAt

    @@index([status])
    @@map("shop_plans")
}

/// *
/// * Enumerations
enum PlanName {
    FREE
    PRO
}

enum ShopifySubscriptionStatus {
    ACTIVE
    CANCELLED
    DECLINED
    EXPIRED
    FROZEN
    PENDING
}

enum BundleType {
    FIXED_BUNDLE
    BUY_X_GET_Y
    BOGO
    VOLUME_DISCOUNT
    MIX_AND_MATCH
    FREQUENTLY_BOUGHT_TOGETHER
}

enum BundleStatus {
    DRAFT
    ACTIVE
    PAUSED
    ARCHIVED
    SCHEDULED
    DELETED
}

enum DiscountType {
    PERCENTAGE
    FIXED_AMOUNT
    CUSTOM_PRICE
    NO_DISCOUNT
    QUANTITY_BREAKS
}

enum BundleProductRole {
    TRIGGER
    REWARD
    INCLUDED
    OPTIONAL
    GROUP_OPTION
}

enum TestType {
    PRICING
    PRODUCT_MIX
    COPY
    LAYOUT
}

enum TestStatus {
    DRAFT
    RUNNING
    COMPLETED
    STOPPED
}

enum AutomationStatus {
    ACTIVE
    PAUSED
    ARCHIVED
}

enum TriggerType {
    SCHEDULE
    PERFORMANCE
    INVENTORY
    CUSTOMER_BEHAVIOR
}

enum AIInsightType {
    RECOMMENDATION
    OPTIMIZATION
    PREDICTION
    WARNING
}

enum NotificationType {
    BUNDLE_PERFORMANCE
    AI_RECOMMENDATION
    TEST_COMPLETED
    AUTOMATION_ERROR
    MILESTONE_REACHED
}

enum NotificationPriority {
    LOW
    NORMAL
    HIGH
    CRITICAL
}

enum AlertRuleStatus {
    ACTIVE
    PAUSED
}

enum AlertFrequency {
    IMMEDIATE
    HOURLY
    DAILY
}

enum ShopStatus {
    ACTIVE
    SUSPENDED
    TRIAL_EXPIRED
    NOT_CONFIGURED
}
