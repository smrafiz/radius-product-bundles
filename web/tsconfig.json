{
    "compilerOptions": {
        "target": "es5",
        "lib": ["dom", "dom.iterable", "esnext"],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "preserve",
        "incremental": true,
        "plugins": [
            {
                "name": "next"
            }
        ],
        "paths": {
			"@/*": ["./*"],
			"@/features/*": ["./features/*"],
			"@/shared/*": ["./shared/*"],
			"@/lib/*": ["./lib/*"],
			"@/tests/*": ["./tests/*"],
			"@/config/*": ["./config/*"],
			"@/providers/*": ["./providers/*"],

			// Temporary backwards compatibility
			"@/actions": ["./actions"],
			"@/actions/*": ["./actions/*"],
			"@/components": ["./components"],
			"@/components/*": ["./components/*"],
			"@/hooks": ["./hooks"],
			"@/hooks/*": ["./hooks/*"],
			"@/stores": ["./stores"],
			"@/stores/*": ["./stores/*"],
			"@/types": ["./types"],
			"@/types/*": ["./types/*"],
			"@/utils": ["./utils"],
			"@/utils/*": ["./utils/*"],
            "@/bundles/*": ["./app/bundles/*"],
            "@/dashboard/*": ["./app/dashboard/*"]
        }
    },
    "include": [
        "../next-env.d.ts",
        "**/*.ts",
        "**/*.tsx",
        ".next/types/**/*.ts",
        ".graphql.ts"
    ],
    "exclude": ["node_modules"]
}
