{% comment %}
  Radius Bundle Pricing Section

  Parameters:
  - show_savings: Boolean
  - show_free_shipping: Boolean
  - regular_price_label: String
  - bundle_price_label: String
  - you_save_label: String
  - free_shipping_label: String
  - compact: Boolean (for compact layout)
  - pricing_summary_box: Boolean (controls box styling via CSS vars)
{% endcomment %}

{% if pricing_summary_box %}
<div class="radius-bundle__pricing{% if compact %} radius-bundle__pricing--compact{% endif %}" data-bundle-pricing>
	{% comment %} Regular Price Row {% endcomment %}
	{% unless compact %}
		<div class="radius-bundle__pricing-row">
			<span class="radius-bundle__pricing-label">{{ regular_price_label }}</span>
			<span class="radius-bundle__price-original" data-regular-price>
                <span class="radius-bundle__skeleton-text radius-bundle__skeleton-text--inline"></span>
            </span>
		</div>
	{% endunless %}

	{% comment %} Bundle Price Row {% endcomment %}
	<div class="radius-bundle__pricing-row{% if compact %} radius-bundle__pricing-row--compact{% endif %}{% unless compact %} radius-bundle__pricing-row--highlight{% endunless %}">
		<span class="radius-bundle__pricing-discounted-label">{{ bundle_price_label }}</span>
		<span class="radius-bundle__price-discounted{% if compact %} radius-bundle__price-discounted--compact{% endif %}" data-bundle-price>
            <span class="radius-bundle__skeleton-text radius-bundle__skeleton-text--inline"></span>
        </span>
	</div>

	{% comment %} Savings Row {% endcomment %}
	{% if show_savings %}
		<div class="radius-bundle__savings{% if compact %} radius-bundle__savings--compact{% endif %}" data-savings>
				<span class="radius-bundle__savings-label">{{ you_save_label }}</span>
			<span class="radius-bundle__savings-amount" data-savings-amount>
                <span class="radius-bundle__skeleton-text radius-bundle__skeleton-text--inline"></span>
            </span>
		</div>
	{% endif %}

	{% comment %} Free Shipping Badge {% endcomment %}
	{% if show_free_shipping %}
		<div class="radius-bundle__free-shipping" data-free-shipping style="display: none;">
			<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
				<path d="M5 18H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h3.93a2 2 0 0 1 1.66.9l.82 1.2a2 2 0 0 0 1.66.9H21a2 2 0 0 1 2 2v1" />
				<circle cx="7" cy="18" r="2" />
				<circle cx="17" cy="18" r="2" />
			</svg>
			<span>{{ free_shipping_label }}</span>
		</div>
	{% endif %}
</div>
{% endif %}