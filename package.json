{
    "name": "radius-product-bundles",
    "description": "AI-powered product bundling for Shopify stores",
    "version": "1.0.0",
    "main": "web/dist/index.js",
    "license": "MIT",
    "scripts": {
        "dev:app": "shopify app dev",
        "dev:widgets": "cd web/widgets && vite build --watch",
        "dev:auto": "node scripts/update-env-host.js",
        "dev:auto-base": "./scripts/dev-with-auto-host.sh",
        "dev:full": "node scripts/update-and-generate.js",
        "dev": "concurrently --raw \"bun:dev:app\" \"bun:dev:widgets\" \"bun:watch:schema\"",
        "build:widgets": "cd web/widgets-src && vite build",
        "info": "shopify app info",
        "build": "shopify app build",
        "generate": "shopify app generate",
        "deploy": "shopify app deploy",
        "pretty": "prettier --write ./",
        "update:config": "bun run web/_developer/tomlWriter.ts; bun run pretty; shopify app deploy;",
        "build:schema": "node extension/scripts/build-schema.js",
        "watch:schema": "nodemon --watch extension/schema/product-bundle-widget -x 'bun run build:schema'"
    },
    "author": "radiustheme",
    "keywords": [
        "shopify",
        "nextjs",
        "polaris",
        "prisma",
        "template"
    ],
    "dependencies": {
        "@iarna/toml": "^2.2.5",
        "prettier": "^3.7.4"
    },
    "private": true,
    "devDependencies": {
        "@types/node": "^25.0.7",
        "concurrently": "^9.2.1",
        "nodemon": "^3.1.11",
        "sass-embedded": "^1.97.2",
        "vite": "^7.3.1"
    }
}
