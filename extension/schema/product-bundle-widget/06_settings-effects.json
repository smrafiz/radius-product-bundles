[
    {
        "type": "header",
        "content": "Effects & Animation"
    },
    {
        "type": "select",
        "id": "shadow_style",
        "label": "Shadow style",
        "info": "Shadow only applies to grid and list layout",
        "options": [
            { "value": "none", "label": "None" },
            { "value": "style1", "label": "Style 1" },
            { "value": "style2", "label": "Style 2" },
            { "value": "style3", "label": "Style 3" }
        ],
        "default": "style1"
    },
    {
        "type": "checkbox",
        "id": "hover_effect",
        "label": "Enable hover effect",
        "default": true,
        "info": "Adds subtle animation on hover"
    },
    {
        "type": "checkbox",
        "id": "display_slider_navigation",
        "label": "Show navigation arrows",
        "default": true,
        "info": "Displays previous and next arrows to help customers navigate the slider."
    },
    {
        "type": "checkbox",
        "id": "display_slider_dots",
        "label": "Show pagination dots",
        "default": true,
        "info": "Displays dots below the slider to indicate the number of slides and the current position."
    },
    {
        "type": "textarea",
        "id": "custom_css_class",
        "label": "Custom CSS class",
        "info": "Add custom class for additional styling"
    }
]
