[
    {
        "type": "header",
        "content": "Layout & Display"
    },
    {
        "type": "select",
        "id": "layout",
        "label": "Display Layout",
        "options": [
            { "value": "", "label": "Use bundle default" },
            { "value": "list", "label": "List" },
            { "value": "grid", "label": "Grid" },
            { "value": "carousel", "label": "Carousel" },
            { "value": "compact", "label": "Compact" }
        ],
        "default": ""
    },
    {
        "type": "range",
        "id": "grid_columns",
        "label": "Grid columns (desktop)",
        "min": 1,
        "max": 4,
        "step": 1,
        "default": 2,
        "info": "Number of products visible per row in grid layout and per slide in slider layout."
    },
    {
        "type": "range",
        "id": "grid_columns_tablet",
        "label": "Grid columns (tablet)",
        "min": 1,
        "max": 4,
        "step": 1,
        "default": 2,
        "info": "Number of products visible per row in grid layout and per slide in slider layout."
    },
    {
        "type": "range",
        "id": "grid_columns_mobile",
        "label": "Grid columns (mobile)",
        "min": 1,
        "max": 4,
        "step": 1,
        "default": 1,
        "info": "Number of products visible per row in grid layout and per slide in slider layout."
    },
    {
        "type": "select",
        "id": "box_alignment",
        "label": "Box alignment",
        "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
        ],
        "default": "center"
    },
    {
        "type": "range",
        "id": "bundle_max_width",
        "label": "Maximum width",
        "visible_if": "{{ block.settings.layout == 'compact' }}",
        "min": 400,
        "max": 1200,
        "step": 10,
        "unit": "px",
        "default": 800,
        "info": "Maximum width of bundle container"
    }
]
