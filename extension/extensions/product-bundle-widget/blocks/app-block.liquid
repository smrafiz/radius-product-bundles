--rb-bogo-card-border-style:{{ bogo_card_border_style }};
{% case shadow %}
{% when 'none' %}
--rb-shadow:none;
--rb-shadow-hover:none;
{% when 'strong' %}
--rb-shadow:0 4px 16px rgba(0, 0, 0, 0.15);
--rb-shadow-hover:0 8px 24px rgba(0, 0, 0, 0.2);
{% else %}
--rb-shadow:0 2px 8px rgba(0, 0, 0, 0.08);
--rb-shadow-hover:0 4px 12px rgba(0, 0, 0, 0.12);
{% endcase %}
{% if product_card_shadow %}
--rb-card-shadow:0 2px 8px rgba(0, 0, 0, 0.08);
--rb-card-shadow-hover:0 4px 12px rgba(0, 0, 0, 0.12);
{% else %}
--rb-card-shadow:none;
--rb-card-shadow-hover:none;
{% endif %}
{% if product_card_border %}
--rb-card-border:1px solid var(--rb-border-color);
{% else %}
--rb-card-border:none;
{% endif %}
{% case heading_size %}
{% when 'small' %}
--rb-heading-font-size:16px;
{% when 'large' %}
--rb-heading-font-size:24px;
{% else %}
--rb-heading-font-size:20px;
{% endcase %}
{% case body_size %}
{% when 'small' %}
--rb-body-font-size:14px;
{% when 'large' %}
--rb-body-font-size:18px;
{% else %}
--rb-body-font-size:16px;
{% endcase %}
{% case button_size %}
{% when 'small' %}
--rb-button-padding:8px 16px;
--rb-button-font-size:14px;
{% when 'large' %}
--rb-button-padding:16px 32px;
--rb-button-font-size:18px;
{% else %}
--rb-button-padding:12px 24px;
--rb-button-font-size:16px;
{% endcase %}
{% if button_style == 'outline' %}
--rb-button-bg:transparent;
--rb-button-text:var(--rb-button-color);
--rb-button-border:2px solid var(--rb-button-color);
{% else %}
--rb-button-bg:var(--rb-button-color);
--rb-button-text:var(--rb-button-text-color);
--rb-button-border:none;
{% endif %}
{% if button_width == 'full' %}
--rb-button-width:100%;
{% else %}
--rb-button-width:auto;
{% endif %}
{% if badge_style == 'outline' %}
