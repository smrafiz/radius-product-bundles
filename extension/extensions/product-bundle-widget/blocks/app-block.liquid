{% comment %}
  Product Bundle Widget - Optimized Hybrid Approach

  Architecture:
  1. Liquid reads structural data from shop metafield (zero API calls)
  2. Passes critical data to JS: product count, IDs, discount config
  3. JS renders accurate skeleton immediately (exact product count)
  4. JS fetches only product details (name, image, price) in ONE API call
  5. Progressive enhancement with fallbacks

  Performance: ~50ms first paint, ~250ms fully interactive
{% endcomment %}

{% assign bundle_ids = product.metafields.radius_bundles.bundle_ids.value %}

{% if bundle_ids != blank and bundle_ids.size > 0 %}
    {% comment %} Load settings from shop metafields (single source of truth) {% endcomment %}
    {% assign global = shop.metafields.radius_bundles.global_settings.value %}
    {% assign bundles = shop.metafields.radius_bundles.active_bundles.value %}

	{{ global }}

    {% comment %} Resolve global defaults {% endcomment %}
    {% assign g_labels = global.labels %}
    {% assign g_styles = global.styles %}

    <div
            class="radius-bundle-widget"
            data-product-id="{{ product.id | prepend: 'gid://shopify/Product/' }}"
            data-shop="{{ shop.permanent_domain }}"
    >
        {% for bundle_id in bundle_ids %}
            {% assign bundle = bundles[bundle_id] %}

            {% if bundle and bundle.status == 'ACTIVE' %}
                {% comment %} Colors {% endcomment %}
                {% assign primary_color = block.settings.primary_color
                        | default: g_styles.primaryColor
                        | default: '#303030' %}

                {% assign secondary_color = block.settings.secondary_color
                        | default: g_styles.secondaryColor
                        | default: '#666666' %}

                {% assign background_color = block.settings.background_color
                        | default: g_styles.boxBgColor
                        | default: '#ffffff' %}

				{% assign box_border_color = g_styles.boxBorderColor
						| default: '#e1e1e1' %}

                {% assign heading_color = block.settings.heading_color
                        | default: g_styles.headingColor
                        | default: '#303030' %}

				{% assign inner_background_color = block.settings.inner_background_color
						| default: g_styles.productBgColor
						| default: '#f7f7f7' %}

				{% assign text_color = block.settings.text_color
						| default: g_styles.productTextColor
						| default: g_styles.textColor
						| default: '#333333' %}

				{% assign border_color = block.settings.border_color
						| default: g_styles.productBorderColor
						| default: '#e1e1e1' %}

				{% assign button_color = block.settings.button_color
						| default: g_styles.buttonBgColor
						| default: '#333333' %}
				{% assign button_text_color = block.settings.button_text_color
						| default: g_styles.buttonTextColor
						| default: '#ffffff' %}
				{% assign button_hover_bg_color =  g_styles.buttonHoverBgColor
						| default: '#666666' %}
				{% assign button_hover_text_color =  g_styles.buttonHoverTextColor
						| default: '#ffffff' %}

				{% assign savings_color = block.settings.savings_color
						| default: g_styles.badgeBgColor
						| default: '#333333' %}
				{% assign savings_text_color = block.settings.savings_text_color
						| default: g_styles.badgeTextColor
						| default: '#ffffff' %}

                {% comment %} Layout {% endcomment %}
                {% assign layout = block.settings.layout
                        | default: bundle.layout
                        | default: 'list' %}

				{% assign bundle_max_width = block.settings.bundle_max_width
						| default: g_styles.boxMaxWidth
						| default: 800 %}

                {% assign box_radius = block.settings.box_radius
                        | default: g_styles.boxRadius
                        | default: 12 %}

				{% assign border_radius = block.settings.border_radius
                        | default: g_styles.productRadius
                        | default: 12 %}

				{% assign button_border_radius = block.settings.button_border_radius
						| default: g_styles.buttonRadius
						| default: 8 %}

				{% assign image_border_radius = block.settings.image_border_radius
						| default: g_styles.borders.imageRadius
						| default: 8 %}

				{% assign image_size = block.settings.image_size
						| default: g_styles.images.imageSize
						| default: 70 %}

				{% assign box_spacing = block.settings.box_spacing
						| default: g_styles.spacing.boxSpacing
						| default: 16 %}

				{% assign box_border_width = g_styles.boxBorderWidth | default: 1 %}

				{% assign heading_size = block.settings.heading_size | default: 'medium' %}
				{% assign text_size = block.settings.text_size | default: 'medium' %}
				{% assign button_size = block.settings.button_size | default: 'medium' %}
				{% assign savings_badge_size = block.settings.savings_badge_size | default: 'medium' %}
				{% assign image_fit = block.settings.image_fit | default: 'contain' %}

				{% assign heading_transform = block.settings.heading_transform
						| default: g_styles.headingTransform %}

				{% assign box_alignment = block.settings.box_alignment
						| default: g_styles.boxAlignment
						| default: 'center' %}

				{% assign show_images = bundle.showImages %}
				{% assign show_savings = bundle.showSavings %}
				{% assign show_product_prices = bundle.showPrices %}
				{% assign show_compare_at_price = bundle.showComparePrices %}
				{% assign show_quantity = bundle.showQuantity %}
				{% assign show_free_shipping = bundle.showFreeShipping %}
				{% assign show_savings_badge = bundle.showSavingsBadge %}
				{% assign enable_hyperlink = bundle.enableHyperLink %}

				{% if show_images == null %}
					{% assign show_images = true %}
				{% endif %}
				{% if show_savings == null %}
					{% assign show_savings = true %}
				{% endif %}
				{% if show_product_prices == null %}
					{% assign show_product_prices = true %}
				{% endif %}
				{% if show_compare_at_price == null %}
					{% assign show_compare_at_price = true %}
				{% endif %}
				{% if show_quantity == null %}
					{% assign show_quantity = true %}
				{% endif %}
				{% if show_free_shipping == null %}
					{% assign show_free_shipping = true %}
				{% endif %}
				{% if show_savings_badge == null %}
					{% assign show_savings_badge = true %}
				{% endif %}
				{% unless enable_hyperlink == true or enable_hyperlink == false %}
					{% assign enable_hyperlink = false %}
				{% endunless %}

				{% assign hover_effect = block.settings.hover_effect %}
				{% if hover_effect == null %}
					{% assign hover_effect = true %}
				{% endif %}

				{% assign show_slider_navigation = block.settings.display_slider_navigation %}
				{% if show_slider_navigation == null %}
					{% assign show_slider_navigation = true %}
				{% endif %}

				{% assign show_slider_dots = block.settings.display_slider_dots %}
				{% if show_slider_dots == null %}
					{% assign show_slider_dots = true %}
				{% endif %}

                {% comment %} Labels {% endcomment %}
				{% assign bundle_heading = block.settings.bundle_heading
						| default: bundle.title
						| default: g_labels.headingLabel
						| default: 'Bundle & Save' %}
                {% assign button_text = block.settings.button_text
                        | default: bundle.buttonText
                        | default: g_labels.addToCartText
                        | default: 'Add bundle to cart' %}
				{% assign regular_price_label = block.settings.regular_price_label
						| default: bundle.regularPriceLabel
						| default: 'Regular price' %}
                {% assign bundle_price_label = block.settings.bundle_price_label
						| default: bundle.bundlePriceLabel
                        | default: 'Bundle price:' %}
                {% assign you_save_label = block.settings.you_save_label
						| default: bundle.youSaveLabel
                        | default: 'You save:' %}
                {% assign free_shipping_label = block.settings.free_shipping_label
						| default: bundle.freeShippingLabel
                        | default: 'Free shipping included' %}

                {% comment %} (DO NOT REMOVE) Build JSON for JS. Formatted structure (DO NOT REMOVE)
                    "id": "{{ bundle_id }}",
                    "status": "{{ bundle.status }}",
                    "discountType": "{{ bundle.discountType }}",
                    "discountValue": {{ bundle.discountValue | default: 0 }},
                    "freeShipping": {{ bundle.freeShipping | default: false }},
                    "minOrderValue": {{ bundle.minOrderValue | default: 0 }},
                    "maxDiscountAmount": {{ bundle.maxDiscountAmount | default: 0 }},
                    "discountApplication": "{{ bundle.discountApplication | default: 'bundle' }}",
                    "discountedProductIds": {{ bundle.discountedProductIds | default: '[]' | json }},
                    "productCount": {{ bundle.productCount | default: 0 }},
                    "productIds": {{ bundle.productIds | default: '[]' | json }},
                    "layout": "{{ layout }}",
                    "labels": {
                    		"heading": "{{ bundle_heading | escape }}"
                            "buttonText": "{{ button_text | escape }}",
                            "regularPriceLabel": "{{ regular_price_label | escape }}",
                            "bundlePriceLabel": "{{ bundle_price_label | escape }}",
                            "youSaveLabel": "{{ you_save_label | escape }}",
                            "freeShippingLabel": "{{ free_shipping_label | escape }}"
                        }
                    }
                {% endcomment %}
                {% capture bundle_structure_json %}{"id": "{{ bundle_id }}","status": "{{ bundle.status }}","discountType": "{{ bundle.discountType }}","discountValue": {{ bundle.discountValue | default: 0 }},"freeShipping": {{ bundle.freeShipping | default: false }},"minOrderValue": {{ bundle.minOrderValue | default: 0 }},"maxDiscountAmount": {{ bundle.maxDiscountAmount | default: 0 }},"discountApplication": "{{ bundle.discountApplication | default: 'bundle' }}","discountedProductIds": {{ bundle.discountedProductIds | default: '[]' | json }},"productCount": {{ bundle.productCount | default: 0 }},"productIds": {{ bundle.productIds | default: '[]' | json }},"layout": "{{ layout }}","labels": {"heading": "{{ bundle_heading | escape }}","buttonText": "{{ button_text | escape }}","regularPriceLabel": "{{ regular_price_label | escape }}","bundlePriceLabel": "{{ bundle_price_label | escape }}","youSaveLabel": "{{ you_save_label | escape }}","freeShippingLabel": "{{ free_shipping_label | escape }}"}}
                {% endcapture %}

                {% comment %} Inject CSS variables {% endcomment %}
				<style>
					#radius-bundle-{{ bundle_id }} {
						/* Colors */
						--rb-primary-color: {{ primary_color }};
						--rb-secondary-color: {{ secondary_color }};
						--rb-background-color: {{ background_color }};
						--rb-box-border-color: {{ box_border_color }};
						--rb-border-color: {{ border_color }};
						--rb-heading-color: {{ heading_color }};
						--rb-product-bg-color: {{ inner_background_color }};
						--rb-text-color: {{ text_color }};
						--rb-savings-color: {{ savings_color }};
						--rb-savings-text-color: {{ savings_text_color }};
						--rb-button-color: {{ button_color }};
						--rb-button-text-color: {{ button_text_color }};
						--rb-button-hover-bg-color: {{ button_hover_bg_color }};
						--rb-button-hover-text-color: {{ button_hover_text_color }};

						/* Radius & spacing */
						--rb-box-radius: {{ box_radius }}px;
						--rb-border-radius: {{ border_radius }}px;
						--rb-border-radius-small: {{ button_border_radius }}px;
						--rb-image-border-radius: {{ image_border_radius }}px;
						--rb-box-spacing: {{ box_spacing }}px;
						--rb-bundle-max-width: {{ bundle_max_width }}px;
						--rb-box-border-width: {{ box_border_width }}px;


						{% if image_size %}
							--rb-image-size: {{ image_size }}px;
						{% endif %}
						--rb-image-fit: {{ image_fit }};
						--rb-heading-transform: {{ heading_transform }};

						/* Heading size */
						{% case heading_size %}
						{% when 'small' %}
							--rb-heading-font: var(--rb-heading-sm);
						{% when 'large' %}
							--rb-heading-font: var(--rb-heading-lg);
						{% else %}
							--rb-heading-font: var(--rb-heading-md);
						{% endcase %}

						/* Button size */
						{% case button_size %}
						{% when 'small' %}
							--rb-button-font: var(--rb-button-font-sm);
						{% when 'large' %}
							--rb-button-font: var(--rb-button-font-lg);
						{% else %}
							--rb-button-font: var(--rb-button-font-md);
						{% endcase %}

						/* Button size */
						{% case savings_badge_size %}
						{% when 'small' %}
							--rb-badge-font: var(--rb-button-font-sm);
						{% when 'large' %}
							--rb-badge-font: var(--rb-button-font-lg);
						{% else %}
							--rb-badge-font: var(--rb-button-font-md);
						{% endcase %}

							/* Text size */
						{% case text_size %}
						{% when 'small' %}
							--rb-font-size: var(--rb-body-font-sm);
						{% when 'large' %}
							--rb-font-size: var(--rb-body-font-lg);
						{% else %}
							--rb-font-size: var(--rb-body-font-md);
						{% endcase %}

						/* product shadow */
						{% case block.settings.shadow_style %}
						{% when 'none' %}
							--rb-shadow: none;
							--rb-shadow-hover: none;
						{% when 'style2' %}
							--rb-shadow: var(--rb-shadow-md);
							--rb-shadow-hover: var(--rb-shadow-md-hover);
						{% when 'style3' %}
							--rb-shadow: var(--rb-shadow-lg);
							--rb-shadow-hover: var(--rb-shadow-lg-hover);
						{% else %}
							--rb-shadow: var(--rb-shadow-sm);
							--rb-shadow-hover: var(--rb-shadow-sm-hover);
						{% endcase %}

						/* Hover effect */
						{% if block.settings.hover_effect %}
							--rb-hover-enabled: 1;
							--rb-hover-transition: 0.25s ease;
						{% else %}
							--rb-hover-enabled: 0;
							--rb-hover-transition: 0s;
						{% endif %}

					}
				</style>

				<div
                        id="radius-bundle-{{ bundle_id }}"
                        class="radius-bundle radius-bundle--{{ layout | downcase }}"
                        data-bundle-id="{{ bundle_id }}"
						data-box-align="{{ box_alignment }}"
						data-show-navigation="{{ show_slider_navigation }}"
						data-show-pagination="{{ show_slider_dots }}"
                        data-bundle-structure='{{ bundle_structure_json | strip_newlines | strip }}'
                        data-show-images="{{ show_images }}"
						data-show-savings="{{ show_savings }}"
                        data-show-prices="{{ show_product_prices }}"
                        data-show-compare-prices="{{ show_compare_at_price }}"
						data-show-quantity="{{ show_quantity }}"
						data-show-free-shipping="{{ show_free_shipping }}"
						data-show-savings-badge="{{ show_savings_badge }}"
						data-enable-hyperlink="{{ enable_hyperlink }}"
                >
                    {% assign layout = layout | default: 'list' | downcase %}

                    {% comment %} Get product count for accurate skeleton {% endcomment %}
                    {% assign product_count = bundle.productCount | default: 0 %}
                    {% if product_count == 0 %}
                        {% assign product_ids = bundle.productIds | default: empty %}
                        {% assign product_count = product_ids | size %}
                    {% endif %}
                    {% if product_count == 0 %}
                        {% assign product_count = 3 %}
                    {% endif %}

                    {% case layout %}
                        {% when 'grid' %}
                            {% render 'radius-bundle-layout-grid',
                                    bundle_id: bundle_id,
                                    name: bundle_heading,
                                    product_count: product_count,
                                    show_images: show_images,
                                    show_savings: show_savings,
									show_savings_badge: show_savings_badge,
									show_product_prices: show_product_prices,
									show_compare_at_price: show_compare_at_price,
									show_quantity: show_quantity,
                                    show_free_shipping: show_free_shipping,
									enable_hyperlink: enable_hyperlink,
                                    button_text: button_text,
                                    regular_price_label: regular_price_label,
                                    bundle_price_label: bundle_price_label,
                                    you_save_label: you_save_label,
                                    free_shipping_label: free_shipping_label,
                                    block: block
                            %}
                        {% when 'carousel' %}
                            {% render 'radius-bundle-layout-carousel',
                                    bundle_id: bundle_id,
                                    name: bundle_heading,
                                    product_count: product_count,
									show_images: show_images,
									show_savings: show_savings,
									show_savings_badge: show_savings_badge,
									show_product_prices: show_product_prices,
									show_compare_at_price: show_compare_at_price,
									show_quantity: show_quantity,
									show_free_shipping: show_free_shipping,
									enable_hyperlink: enable_hyperlink,
                                    button_text: button_text,
                                    regular_price_label: regular_price_label,
                                    bundle_price_label: bundle_price_label,
                                    you_save_label: you_save_label,
                                    free_shipping_label: free_shipping_label,
                                    block: block
                            %}
                        {% when 'compact' %}
                            {% render 'radius-bundle-layout-compact',
                                    bundle_id: bundle_id,
                                    name: bundle_heading,
                                    product_count: product_count,
									show_images: show_images,
									show_savings: show_savings,
									show_savings_badge: show_savings_badge,
									show_product_prices: show_product_prices,
									show_compare_at_price: show_compare_at_price,
									show_quantity: show_quantity,
									show_free_shipping: show_free_shipping,
									enable_hyperlink: enable_hyperlink,
                                    button_text: button_text,
                                    regular_price_label: regular_price_label,
                                    bundle_price_label: bundle_price_label,
                                    you_save_label: you_save_label,
                                    free_shipping_label: free_shipping_label,
                                    block: block
                            %}
                        {% else %}
                            {% render 'radius-bundle-layout-list',
                                    bundle_id: bundle_id,
                                    name: bundle_heading,
                                    product_count: product_count,
									show_images: show_images,
									show_savings: show_savings,
									show_savings_badge: show_savings_badge,
									show_product_prices: show_product_prices,
									show_compare_at_price: show_compare_at_price,
									show_quantity: show_quantity,
									show_free_shipping: show_free_shipping,
									enable_hyperlink: enable_hyperlink,
                                    button_text: button_text,
                                    regular_price_label: regular_price_label,
                                    bundle_price_label: bundle_price_label,
                                    you_save_label: you_save_label,
                                    free_shipping_label: free_shipping_label,
                                    block: block
                            %}
                    {% endcase %}
                </div>
            {% endif %}
        {% endfor %}
    </div>

    {{ 'bundle-widget.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'bundle-widget.js' | asset_url }}" defer></script>
{% endif %}

{% comment %} DO NOT TOUCH BELOW SCHEMA. IT IS AUTOMATICALLY GENERATED {% endcomment %}
