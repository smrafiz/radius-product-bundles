{% comment %}
  Bundle Savings Summary - Cart Block
  Displays bundle savings message in cart
{% endcomment %}

<div id="bundle-savings-container" style="display: none;">
    <div class="bundle-savings-summary">
        <span class="bundle-savings-icon">🎉</span>
        <span class="bundle-savings-text"></span>
    </div>
</div>

<style>
	.bundle-savings-summary {
		background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
		border: 1px solid #4caf50;
		border-radius: 8px;
		padding: 12px 16px;
		margin: 16px 0;
		display: flex;
		align-items: center;
		gap: 8px;
	}

	.bundle-savings-icon {
		font-size: 1.2em;
	}

	.bundle-savings-text {
		color: #2e7d32;
		font-weight: 500;
		flex: 1;
	}
</style>

<script>
    (function() {
        async function updateBundleSavings() {
            try {
                const response = await fetch('/cart.js');
                const cart = await response.json();

                const container = document.getElementById('bundle-savings-container');
                const textEl = container?.querySelector('.bundle-savings-text');

                if (!container || !textEl) return;

                const bundleDiscountsRaw = cart.attributes?._radiusDiscounts;
                if (!bundleDiscountsRaw) {
                    container.style.display = 'none';
                    return;
                }

                const bundles = JSON.parse(bundleDiscountsRaw);
                if (!bundles || bundles.length === 0) {
                    container.style.display = 'none';
                    return;
                }

                // Build savings messages
                const messages = bundles.map(bundle => {
                    const name = bundle.bundleName || 'this bundle';
                    switch (bundle.discountType) {
                        case 'PERCENTAGE':
                            messages.push(`You're saving ${bundle.discountValue}% with ${name}!`);
                            break;
                        case 'FIXED_AMOUNT':
                            messages.push(`You're saving $${bundle.discountValue.toFixed(2)} with ${name}!`);
                            break;
                        case 'CUSTOM_PRICE':
                            messages.push(`Special bundle price: $${bundle.discountValue.toFixed(2)} for ${name}`);
                            break;
                        case 'NO_DISCOUNT':
                            // No message
                            break;
                    }
                });

                textEl.textContent = messages.join(' ');
                container.style.display = 'block';

            } catch (error) {
                console.error('Bundle savings error:', error);
            }
        }

        // Run on page load
        updateBundleSavings();

        // Listen for cart updates
        document.addEventListener('cart:updated', updateBundleSavings);
    })();
</script>

{% schema %}
{
	"name": "Bundle Savings",
	"target": "section",
	"settings": []
}
{% endschema %}