{% comment %}
  Radius Bundles App Embed
  Loads external JS/CSS assets and initializes configuration
{% endcomment %}

{% assign active_bundles_raw = shop.metafields.radius_bundles.active_bundles.value %}
{% assign global = shop.metafields.radius_bundles.global_settings.value %}

{% assign styles = global.styles %}
{% assign g_tablet = styles.tablet %}
{% assign g_mobile = styles.mobile %}
{% assign tablet_bp = styles.tabletBreakpoint | default: 1024 %}
{% assign mobile_bp = styles.mobileBreakpoint | default: 768 %}

<script>
    console.log({{ styles | json }});
</script>

{% assign text_color = styles.cartBannerTextColor | default: '#333333' %}
{% assign bg_color = styles.cartBannerBgColor | default: '#ffffff' %}
{% assign border_color = styles.cartBannerBorderColor | default: '#303030' %}
{% assign highlight_color = styles.cartBannerHighlightColor | default: '#303030' %}
{% assign border_style = styles.cartBannerBorderStyle | default: 'solid' %}
{% assign corner_style = styles.cartBannerCornerStyle | default: 'modern' %}
{% assign shadow = styles.cartBannerShadow | default: 'none' %}
{% assign spacing = styles.cartBannerSpacing | default: 'comfortable' %}
{% assign body_size = styles.cartBannerBodySize | default: 'medium' %}
{% assign icon_type = styles.cartBannerIconType | default: 'tag' %}
{% assign icon_color = styles.cartBannerIconColor | default: '#303030' %}

{% case corner_style %}
    {% when 'sharp' %}
        {% assign border_radius = '0px' %}
    {% when 'rounded' %}
        {% assign border_radius = '20px' %}
    {% else %}
        {% assign border_radius = '8px' %}
{% endcase %}

{% case shadow %}
    {% when 'none' %}
        {% assign box_shadow = 'none' %}
    {% when 'strong' %}
        {% assign box_shadow = '0 4px 16px rgba(0, 0, 0, 0.15)' %}
    {% else %}
        {% assign box_shadow = '0 2px 8px rgba(0, 0, 0, 0.08)' %}
{% endcase %}

{% case spacing %}
    {% when 'compact' %}
        {% assign padding = '12px' %}
    {% when 'spacious' %}
        {% assign padding = '28px' %}
    {% else %}
        {% assign padding = '20px' %}
{% endcase %}

{% case body_size %}
    {% when 'small' %}
        {% assign font_size = '13px' %}
    {% when 'large' %}
        {% assign font_size = '16px' %}
    {% else %}
        {% assign font_size = '14px' %}
{% endcase %}

{% comment %} Responsive overrides for cart banner {% endcomment %}
{% if g_tablet.cartBannerSpacing %}
	{% case g_tablet.cartBannerSpacing %}
		{% when 'compact' %}{% assign tablet_cb_padding = '12px' %}
		{% when 'spacious' %}{% assign tablet_cb_padding = '28px' %}
		{% else %}{% assign tablet_cb_padding = '20px' %}
	{% endcase %}
{% endif %}
{% if g_tablet.cartBannerBodySize %}
	{% case g_tablet.cartBannerBodySize %}
		{% when 'small' %}{% assign tablet_cb_font_size = '13px' %}
		{% when 'large' %}{% assign tablet_cb_font_size = '16px' %}
		{% else %}{% assign tablet_cb_font_size = '14px' %}
	{% endcase %}
{% endif %}
{% if g_mobile.cartBannerSpacing %}
	{% case g_mobile.cartBannerSpacing %}
		{% when 'compact' %}{% assign mobile_cb_padding = '12px' %}
		{% when 'spacious' %}{% assign mobile_cb_padding = '28px' %}
		{% else %}{% assign mobile_cb_padding = '20px' %}
	{% endcase %}
{% endif %}
{% if g_mobile.cartBannerBodySize %}
	{% case g_mobile.cartBannerBodySize %}
		{% when 'small' %}{% assign mobile_cb_font_size = '13px' %}
		{% when 'large' %}{% assign mobile_cb_font_size = '16px' %}
		{% else %}{% assign mobile_cb_font_size = '14px' %}
	{% endcase %}
{% endif %}

{% capture icon_svg %}
    {% case icon_type %}

        {% when 'tag' %}
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" style="flex-shrink:0;">
                <path
                        d="M2 4a2 2 0 0 1 2-2h4.586a2 2 0 0 1 1.414.586l7 7a2 2 0 0 1 0 2.828l-4.586 4.586a2 2 0 0 1-2.828 0l-7-7A2 2 0 0 1 2 8.586V4Zm4.5 3a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z"
                        fill="{{ icon_color }}"
                />
            </svg>

        {% when 'percent' %}
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" style="flex-shrink:0;">
                <circle cx="6.5" cy="6.5" r="2.5" stroke="{{ icon_color }}" stroke-width="1.5" fill="none" />
                <circle cx="13.5" cy="13.5" r="2.5" stroke="{{ icon_color }}" stroke-width="1.5" fill="none" />
                <line x1="15" y1="5" x2="5" y2="15" stroke="{{ icon_color }}" stroke-width="1.5"
                      stroke-linecap="round" />
            </svg>

        {% when 'gift' %}
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" style="flex-shrink:0;">
                <rect x="2" y="8" width="16" height="4" rx="1" stroke="{{ icon_color }}" stroke-width="1.5"
                      fill="none" />
                <rect x="4" y="12" width="12" height="6" rx="1" stroke="{{ icon_color }}" stroke-width="1.5"
                      fill="none" />
                <line x1="10" y1="8" x2="10" y2="18" stroke="{{ icon_color }}" stroke-width="1.5" />
                <path d="M10 8C10 8 10 4 7 3C4 2 4 5 5.5 6C7 7 10 8 10 8Z" stroke="{{ icon_color }}" stroke-width="1.3"
                      fill="none" />
                <path d="M10 8C10 8 10 4 13 3C16 2 16 5 14.5 6C13 7 10 8 10 8Z" stroke="{{ icon_color }}"
                      stroke-width="1.3" fill="none" />
            </svg>

        {% when 'sparkle' %}
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" style="flex-shrink:0;">
                <path
                        d="M10 1L11.8 7.2H18.2L13.2 11L15 17.2L10 13.4L5 17.2L6.8 11L1.8 7.2H8.2L10 1Z"
                        fill="{{ icon_color }}"
                />
            </svg>

        {% when 'fire' %}
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" style="flex-shrink:0;">
                <path
                        d="M10 1C10 1 5 7 5 12a5 5 0 0 0 10 0c0-5-5-11-5-11Zm0 14a2 2 0 0 1-2-2c0-1.5 2-4 2-4s2 2.5 2 4a2 2 0 0 1-2 2Z"
                        fill="{{ icon_color }}"
                />
            </svg>

        {% when 'check' %}
            <svg width="16" height="16" viewBox="0 0 20 20" fill="none" style="flex-shrink:0;">
                <circle cx="10" cy="10" r="8" stroke="{{ icon_color }}" stroke-width="1.5" fill="none" />
                <path
                        d="M6 10l3 3 5-6"
                        stroke="{{ icon_color }}"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        fill="none"
                />
            </svg>

        {% else %}
            {%- comment -%} No icon {%- endcomment -%}

    {% endcase %}
{% endcapture %}

<!-- Load CSS -->
{{ 'radius-bundles.css' | asset_url | stylesheet_tag }}

{% comment %} Hide third-party payment buttons if enabled {% endcomment %}
{% if global.cart.hidePaymentButtons %}
<script>document.documentElement.classList.add('radius-hide-payment-buttons');</script>
{% endif %}

<!-- Initialize Configuration -->
<script>
    /**
     * Get customer ID from various Shopify sources
     * Only returns numeric Shopify customer IDs
     */
    function getCustomerId() {
        let customerId = null;

        // Try ShopifyAnalytics.meta.page.customerId
        try {
            let curr = window.ShopifyAnalytics.meta.page.customerId;
            if (curr !== undefined && curr !== null && curr !== "") {
                customerId = String(curr);
            }
        } catch (e) {
        }

        // Try window.meta.page.customerId
        if (!customerId) {
            try {
                let curr = window.meta.page.customerId;
                if (curr !== undefined && curr !== null && curr !== "") {
                    customerId = String(curr);
                }
            } catch (e) {
            }
        }

        // Try _st.cid (Shopify tracking)
        if (!customerId) {
            try {
                let curr = window._st.cid;
                if (curr !== undefined && curr !== null && curr !== "") {
                    customerId = String(curr);
                }
            } catch (e) {
            }
        }

        // Fallback to Liquid customer.id if available
        {% if customer.id %}
        if (!customerId) {
            customerId = "{{ customer.id }}";
        }
        {% endif %}

        // ✅ VALIDATE: Only return if it's a numeric ID
        if (customerId && /^\d+$/.test(customerId)) {
            return customerId;
        }

        return null;
    }

    window.RadiusBundles = window.RadiusBundles || {};
    window.RadiusBundles.config = {
        shop: "{{ shop.permanent_domain }}",
        customerId: getCustomerId(),
        pageType: "{{ request.page_type }}",
        template: "{{ template.name }}",
        enableAnalytics: {{ block.settings.enable_analytics | default: true | json }},
        showSavingsBanner: {{ block.settings.show_savings_banner | default: true | json }},
        activeBundles: {{ active_bundles_raw | json }}
    };

    console.log("[RadiusBundles] Customer ID:", window.RadiusBundles.config.customerId);
</script>

<!-- Load JavaScript -->
<script src="{{ 'radius-bundles.js' | asset_url }}" defer></script>

<!-- Cart Savings Banner Container -->
{% if request.page_type == 'cart' %}
    <style>
        .radius-savings-banner {
            --cb-padding: {{ padding }};
            --cb-font-size: {{ font_size }};
        }
        {% if g_tablet %}
        @media (max-width: {{ tablet_bp }}px) {
            .radius-savings-banner {
                {% if tablet_cb_padding %}--cb-padding: {{ tablet_cb_padding }};{% endif %}
                {% if tablet_cb_font_size %}--cb-font-size: {{ tablet_cb_font_size }};{% endif %}
            }
        }
        {% endif %}
        {% if g_mobile %}
        @media (max-width: {{ mobile_bp }}px) {
            .radius-savings-banner {
                {% if mobile_cb_padding %}--cb-padding: {{ mobile_cb_padding }};{% endif %}
                {% if mobile_cb_font_size %}--cb-font-size: {{ mobile_cb_font_size }};{% endif %}
            }
        }
        {% endif %}
    </style>

    <div id="radius-bundle-savings" data-highlight-color="{{ highlight_color }}" style="display: none;">
        <div
                class="radius-savings-banner"
                style="
                        background-color: {{ bg_color }};
                        border: 2px {{ border_style }} {{ border_color }};
                        border-radius: {{ border_radius }};
                        box-shadow: {{ box_shadow }};
                        padding: var(--cb-padding);
                        font-size: var(--cb-font-size);
                        color: {{ text_color }};
                        "
        >

            {% unless icon_type == 'none' %}
                <span class="radius-savings-banner__icon">
				{{ icon_svg }}
			</span>
            {% endunless %}

            <div class="radius-savings-banner__content"></div>
        </div>
    </div>
{% endif %}

{% schema %}
{
  "name": "Radius Bundles",
  "target": "body"
}
{% endschema %}