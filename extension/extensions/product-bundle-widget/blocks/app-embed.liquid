{% assign active_bundles_raw = shop.metafields['$app'].active_bundles.value %}
{% assign global = shop.metafields['$app'].global_settings.value %}
{% assign styles = global.styles %}
{% assign g_tablet = styles.tablet %}
{% assign g_mobile = styles.mobile %}
{% assign tablet_bp = styles.tabletBreakpoint | default: 1024 %}
{% assign mobile_bp = styles.mobileBreakpoint | default: 768 %}
{% assign text_color = styles.cartBannerTextColor | default: '#333333' %}
{% assign bg_color = styles.cartBannerBgColor | default: '#ffffff' %}
{% assign border_color = styles.cartBannerBorderColor | default: '#303030' %}
{% assign highlight_color = styles.cartBannerHighlightColor | default: '#303030' %}
{% assign border_style = styles.cartBannerBorderStyle | default: 'solid' %}
{% assign corner_style = styles.cartBannerCornerStyle | default: 'modern' %}
{% assign shadow = styles.cartBannerShadow | default: 'none' %}
{% assign spacing = styles.cartBannerSpacing | default: 'comfortable' %}
{% assign body_size = styles.cartBannerBodySize | default: 'medium' %}
{% assign icon_type = styles.cartBannerIconType | default: 'tag' %}
{% assign icon_color = styles.cartBannerIconColor | default: '#303030' %}
{% assign hide_payment_buttons = global.cart.hidePaymentButtons %}
{% assign enable_analytics = global.privacy.enableAnalytics %}
{% assign show_savings_banner = global.cart.showSavingsBanner %}
{% assign lazy_load_images = global.cart.lazyLoadImages %}
{% unless lazy_load_images == true or lazy_load_images == false %}{% assign lazy_load_images = true %}{% endunless %}
{% unless hide_payment_buttons == true or hide_payment_buttons == false %}{% assign hide_payment_buttons = false %}{% endunless %}
{% unless enable_analytics == true or enable_analytics == false %}{% assign enable_analytics = true %}{% endunless %}
{% unless show_savings_banner == true or show_savings_banner == false %}{% assign show_savings_banner = false %}{% endunless %}
{% assign customer_locale = request.locale.iso_code | downcase %}
{% assign primary_locale = global.primaryLocale | default: 'en' %}
{% if global.labels[customer_locale] %}{% assign g_labels_embed = global.labels[customer_locale] %}
{% elsif global.labels[primary_locale] %}{% assign g_labels_embed = global.labels[primary_locale] %}
{% elsif global.labels['en'] %}{% assign g_labels_embed = global.labels['en'] %}
{% else %}{% assign g_labels_embed = global.labels %}{% endif %}
{% assign banner_saving_text = g_labels_embed.bannerSavingText %}
{% assign banner_custom_price_text = g_labels_embed.bannerCustomPriceText %}
{% assign banner_free_shipping_qualify_text = g_labels_embed.bannerFreeShippingQualifyText %}
{% assign banner_free_shipping_text = g_labels_embed.bannerFreeShippingText %}
{% if banner_saving_text == blank %}{% assign banner_saving_text = "You're saving {discount} with {name}" %}{% endif %}
{% if banner_custom_price_text == blank %}{% assign banner_custom_price_text = "Special price: {price} for {name}" %}{% endif %}
{% if banner_free_shipping_qualify_text == blank %}{% assign banner_free_shipping_qualify_text = "{name} qualifies for free shipping!" %}{% endif %}
{% if banner_free_shipping_text == blank %}{% assign banner_free_shipping_text = "Free shipping included!" %}{% endif %}
{% case corner_style %}{% when 'sharp' %}{% assign border_radius = '0px' %}{% when 'rounded' %}{% assign border_radius = '20px' %}{% else %}{% assign border_radius = '8px' %}{% endcase %}
{% case shadow %}{% when 'none' %}{% assign box_shadow = 'none' %}{% when 'strong' %}{% assign box_shadow = '0 4px 16px rgba(0, 0, 0, 0.15)' %}{% else %}{% assign box_shadow = '0 2px 8px rgba(0, 0, 0, 0.08)' %}{% endcase %}
{% case spacing %}{% when 'compact' %}{% assign padding = '12px' %}{% when 'spacious' %}{% assign padding = '28px' %}{% else %}{% assign padding = '20px' %}{% endcase %}
{% case body_size %}{% when 'small' %}{% assign font_size = '13px' %}{% when 'large' %}{% assign font_size = '16px' %}{% else %}{% assign font_size = '14px' %}{% endcase %}
{% if g_tablet.cartBannerSpacing %}{% case g_tablet.cartBannerSpacing %}{% when 'compact' %}{% assign tablet_cb_padding = '12px' %}{% when 'spacious' %}{% assign tablet_cb_padding = '28px' %}{% else %}{% assign tablet_cb_padding = '20px' %}{% endcase %}{% endif %}
{% if g_tablet.cartBannerBodySize %}{% case g_tablet.cartBannerBodySize %}{% when 'small' %}{% assign tablet_cb_font_size = '13px' %}{% when 'large' %}{% assign tablet_cb_font_size = '16px' %}{% else %}{% assign tablet_cb_font_size = '14px' %}{% endcase %}{% endif %}
{% if g_mobile.cartBannerSpacing %}{% case g_mobile.cartBannerSpacing %}{% when 'compact' %}{% assign mobile_cb_padding = '12px' %}{% when 'spacious' %}{% assign mobile_cb_padding = '28px' %}{% else %}{% assign mobile_cb_padding = '20px' %}{% endcase %}{% endif %}
{% if g_mobile.cartBannerBodySize %}{% case g_mobile.cartBannerBodySize %}{% when 'small' %}{% assign mobile_cb_font_size = '13px' %}{% when 'large' %}{% assign mobile_cb_font_size = '16px' %}{% else %}{% assign mobile_cb_font_size = '14px' %}{% endcase %}{% endif %}
{% capture icon_svg %}{% case icon_type %}{% when 'tag' %}<svg width="16" height="16" viewBox="0 0 20 20" fill="none" style="flex-shrink:0"><path d="M2 4a2 2 0 0 1 2-2h4.586a2 2 0 0 1 1.414.586l7 7a2 2 0 0 1 0 2.828l-4.586 4.586a2 2 0 0 1-2.828 0l-7-7A2 2 0 0 1 2 8.586V4Zm4.5 3a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Z" fill="{{ icon_color }}"/></svg>{% when 'percent' %}<svg width="16" height="16" viewBox="0 0 20 20" fill="none" style="flex-shrink:0"><circle cx="6.5" cy="6.5" r="2.5" stroke="{{ icon_color }}" stroke-width="1.5" fill="none"/><circle cx="13.5" cy="13.5" r="2.5" stroke="{{ icon_color }}" stroke-width="1.5" fill="none"/><line x1="15" y1="5" x2="5" y2="15" stroke="{{ icon_color }}" stroke-width="1.5" stroke-linecap="round"/></svg>{% when 'gift' %}<svg width="16" height="16" viewBox="0 0 20 20" fill="none" style="flex-shrink:0"><rect x="2" y="8" width="16" height="4" rx="1" stroke="{{ icon_color }}" stroke-width="1.5" fill="none"/><rect x="4" y="12" width="12" height="6" rx="1" stroke="{{ icon_color }}" stroke-width="1.5" fill="none"/><line x1="10" y1="8" x2="10" y2="18" stroke="{{ icon_color }}" stroke-width="1.5"/><path d="M10 8C10 8 10 4 7 3C4 2 4 5 5.5 6C7 7 10 8 10 8Z" stroke="{{ icon_color }}" stroke-width="1.3" fill="none"/><path d="M10 8C10 8 10 4 13 3C16 2 16 5 14.5 6C13 7 10 8 10 8Z" stroke="{{ icon_color }}" stroke-width="1.3" fill="none"/></svg>{% when 'sparkle' %}<svg width="16" height="16" viewBox="0 0 20 20" fill="none" style="flex-shrink:0"><path d="M10 1L11.8 7.2H18.2L13.2 11L15 17.2L10 13.4L5 17.2L6.8 11L1.8 7.2H8.2L10 1Z" fill="{{ icon_color }}"/></svg>{% when 'fire' %}<svg width="16" height="16" viewBox="0 0 20 20" fill="none" style="flex-shrink:0"><path d="M10 1C10 1 5 7 5 12a5 5 0 0 0 10 0c0-5-5-11-5-11Zm0 14a2 2 0 0 1-2-2c0-1.5 2-4 2-4s2 2.5 2 4a2 2 0 0 1-2 2Z" fill="{{ icon_color }}"/></svg>{% when 'check' %}<svg width="16" height="16" viewBox="0 0 20 20" fill="none" style="flex-shrink:0"><circle cx="10" cy="10" r="8" stroke="{{ icon_color }}" stroke-width="1.5" fill="none"/><path d="M6 10l3 3 5-6" stroke="{{ icon_color }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>{% endcase %}{% endcapture %}
{{ 'radius-bundles.css' | asset_url | stylesheet_tag }}
{% assign custom_css = global.custom.css | default: '' %}
{% if custom_css != blank %}<style>{{ custom_css }}</style>{% endif %}
{% if hide_payment_buttons %}<script>document.documentElement.classList.add('radius-hide-payment-buttons');</script>{% endif %}
<script>
function getCustomerId(){var c=null;try{var v=window.ShopifyAnalytics.meta.page.customerId;if(v!==undefined&&v!==null&&v!=="")c=String(v)}catch(e){}if(!c){try{var v=window.meta.page.customerId;if(v!==undefined&&v!==null&&v!=="")c=String(v)}catch(e){}}if(!c){try{var v=window._st.cid;if(v!==undefined&&v!==null&&v!=="")c=String(v)}catch(e){}}{% if customer.id %}if(!c)c="{{ customer.id }}";{% endif %}if(c&&/^\d+$/.test(c))return c;return null}
window.RadiusBundles=window.RadiusBundles||{};
window.RadiusBundles.config={shop:"{{ shop.permanent_domain }}",customerId:getCustomerId(),pageType:"{{ request.page_type }}",template:"{{ template.name }}",currentProductId:"{{ product.id | default: '' }}",enableAnalytics:{{ enable_analytics | json }},maxBundlesPerOrder:{{ global.cart.maxBundlesPerOrder | default: 0 | json }},showSavingsBanner:{{ show_savings_banner | json }},lazyLoadImages:{{ lazy_load_images | json }},activeBundles:{{ active_bundles_raw | json }},bannerIcon:`{{ icon_svg | strip_newlines | replace: '"', '\\"' }}`,bannerLabels:{savingText:{{ banner_saving_text | json }},customPriceText:{{ banner_custom_price_text | json }},freeShippingQualifyText:{{ banner_free_shipping_qualify_text | json }},freeShippingText:{{ banner_free_shipping_text | json }}}};
</script>
<script src="{{ 'radius-bundles.js' | asset_url }}" defer></script>
{% if request.page_type == 'cart' %}
<style>
.radius-savings-banner{--cb-padding:{{ padding }};--cb-font-size:{{ font_size }};}
{% if g_tablet %}@media(max-width:{{ tablet_bp }}px){.radius-savings-banner{
{% if tablet_cb_padding %}--cb-padding:{{ tablet_cb_padding }};{% endif %}{% if tablet_cb_font_size %}--cb-font-size:{{ tablet_cb_font_size }};{% endif %}}}{% endif %}
{% if g_mobile %}@media(max-width:{{ mobile_bp }}px){.radius-savings-banner{
{% if mobile_cb_padding %}--cb-padding:{{ mobile_cb_padding }};{% endif %}{% if mobile_cb_font_size %}--cb-font-size:{{ mobile_cb_font_size }};{% endif %}}}{% endif %}
</style>
<div id="radius-bundle-savings" data-highlight-color="{{ highlight_color }}" style="display:none;">
<div class="radius-savings-banner" style="background-color:{{ bg_color }};border:2px {{ border_style }} {{ border_color }};border-radius:{{ border_radius }};box-shadow:{{ box_shadow }};padding:var(--cb-padding);font-size:var(--cb-font-size);color:{{ text_color }};">
<div class="radius-savings-banner__content"></div>
</div>
</div>
{% endif %}
{% schema %}
{
"name": "Radius Bundles",
"target": "body"
}
{% endschema %}