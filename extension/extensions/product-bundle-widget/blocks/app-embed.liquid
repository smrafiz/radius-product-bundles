{% comment %}
  Radius Bundles App Embed
  Loads external JS/CSS assets and initializes configuration
{% endcomment %}

{% assign active_bundles_raw = shop.metafields.radius_bundles.active_bundles.value %}

<!-- Load CSS -->
{{ 'radius-bundles.css' | asset_url | stylesheet_tag }}

<!-- Initialize Configuration -->
<script>
    window.RadiusBundles = window.RadiusBundles || {};
    window.RadiusBundles.config = {
        shop: "{{ shop.permanent_domain }}",
        customerId: "{{ customer.id | default: '' }}",
        pageType: "{{ request.page_type }}",
        template: "{{ template.name }}",
        enableAnalytics: {{ block.settings.enable_analytics | default: true }},
        showSavingsBanner: {{ block.settings.show_savings_banner | default: true }},
        activeBundles: {{ active_bundles_raw | json }}
    };
</script>

<!-- Load JavaScript -->
<script src="{{ 'radius-bundles.js' | asset_url }}" defer></script>

<!-- Cart Savings Banner Container -->
{% if request.page_type == 'cart' %}
	<div id="radius-bundle-savings" style="display: none;">
		<div class="radius-savings-banner">
			<span class="radius-savings-banner__icon">🎉</span>
			<div class="radius-savings-banner__content"></div>
		</div>
	</div>
{% endif %}

{% schema %}
{
	"name": "Radius Bundles",
	"target": "body"
}
{% endschema %}