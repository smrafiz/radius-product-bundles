{% comment %}
  Radius Bundle - List Template

  Parameters:
  - bundle_id, name, savings_badge_text, product_count
  - show_images, show_savings, show_savings_badge
  - show_product_prices, show_compare_at_price, show_quantity
  - show_free_shipping, enable_hyperlink
  - button_text, regular_price_label, bundle_price_label
  - you_save_label, free_shipping_label, quantity_label
  - divider_style: 'none' | 'line' | 'plus'
  - pricing_summary_box: Boolean
{% endcomment %}

<div class="radius-bundle__inner">
	{% comment %} Header {% endcomment %}
	{% render 'radius-bundle-header',
			name: name,
			show_savings_badge: show_savings_badge
	%}

	{% comment %} Products List Container {% endcomment %}
	<div class="radius-bundle__products radius-bundle__products--list" data-bundle-products>
		<div class="radius-bundle__loading" data-bundle-loading>
			<div class="radius-bundle__skeleton radius-bundle__skeleton--list">
				{% if more_product_settings %}
					{% assign initial_visible = more_product_count %}
				{% else %}
					{% assign initial_visible = product_count %}
				{% endif %}
				{% assign divider_threshold = initial_visible | minus: 1 %}

				{% for i in (1..product_count) %}
					{% assign item_index = forloop.index0 %}
					{% assign is_hidden = false %}
					{% if item_index >= more_product_count %}
						{% assign is_hidden = true %}
					{% endif %}

					<div class="radius-bundle__skeleton-item radius-bundle__skeleton-item--list{% if is_hidden %} radius-bundle__product--hidden{% endif %}"
						 data-product-index="{{ item_index }}"
						 {% if is_hidden %}style="display: none;"{% endif %}
					>
						{% if show_images %}
							<div class="radius-bundle__skeleton-image"></div>
						{% endif %}
						<div class="radius-bundle__skeleton-content">
							<div class="radius-bundle__skeleton-text radius-bundle__skeleton-text--title"></div>
							<div class="radius-bundle__skeleton-text radius-bundle__skeleton-text--subtitle"></div>
						</div>
						<div class="radius-bundle__skeleton-price-wrapper">
							<div class="radius-bundle__skeleton-text radius-bundle__skeleton-text--price"></div>
							<div class="radius-bundle__skeleton-text radius-bundle__skeleton-text--price"></div>
						</div>
					</div>

					{% unless forloop.last %}
						{% assign divider_hidden = false %}
						{% if item_index >= divider_threshold %}
							{% assign divider_hidden = true %}
						{% endif %}

						{% if divider_style == 'plus' %}
							<div class="radius-bundle__divider radius-bundle__divider--plus{% if divider_hidden %} radius-bundle__divider--hidden{% endif %}"
								 data-divider-index="{{ item_index }}"
								 {% if divider_hidden %}style="display: none;"{% endif %}
							>
								<div class="divider-position">+</div>
							</div>
						{% elsif divider_style == 'line' %}
							<div class="radius-bundle__divider radius-bundle__divider--line{% if divider_hidden %} radius-bundle__divider--hidden{% endif %}"
								 data-divider-index="{{ item_index }}"
								 {% if divider_hidden %}style="display: none;"{% endif %}
							></div>
						{% endif %}
					{% endunless %}
				{% endfor %}
			</div>
		</div>
	</div>

	{% comment %} Pricing Section {% endcomment %}
	{% render 'radius-bundle-pricing',
			show_savings: show_savings,
			show_free_shipping: show_free_shipping,
			regular_price_label: regular_price_label,
			bundle_price_label: bundle_price_label,
			you_save_label: you_save_label,
			free_shipping_label: free_shipping_label,
			pricing_summary_box: pricing_summary_box
	%}

	{% comment %} Add to Cart Button {% endcomment %}
	{% render 'radius-bundle-add-to-cart',
			bundle_id: bundle_id,
			button_text: button_text
	%}
</div>