{% comment %}
  Radius Bundle - Classic Card Template (BOGO/BXGY)

  Parameters:
  - bundle_id, name, subtitle, savings_badge_text, product_count
  - show_images, show_savings, show_savings_badge
  - show_product_prices, show_compare_at_price, show_quantity
  - show_free_shipping, enable_hyperlink
  - button_text, regular_price_label, bundle_price_label
  - you_save_label, free_shipping_label, quantity_label
{% endcomment %}

<div class="radius-bundle__inner">
	{% comment %} Header {% endcomment %}
	{% render 'radius-bundle-header',
			name: name,
			subtitle: subtitle,
			show_savings_badge: show_savings_badge
	%}

	{% comment %} Products Container — JS renders Classic Card here {% endcomment %}
	<div class="radius-bundle__products radius-bundle__products--classic-card" data-bundle-products>
		<div class="radius-bundle__loading" data-bundle-loading>
			<div class="radius-bundle__skeleton radius-bundle__skeleton--classic-card">
				<div class="rb-classic__grid">
					<div class="radius-bundle__skeleton-item" style="flex: 1; min-height: 200px;">
						{% if show_images %}
							<div class="radius-bundle__skeleton-image" style="aspect-ratio: 1/1;"></div>
						{% endif %}
						<div class="radius-bundle__skeleton-content">
							<div class="radius-bundle__skeleton-text radius-bundle__skeleton-text--title"></div>
							<div class="radius-bundle__skeleton-text radius-bundle__skeleton-text--price"></div>
						</div>
					</div>
					<div class="radius-bundle__skeleton-item" style="flex: 1; min-height: 200px;">
						{% if show_images %}
							<div class="radius-bundle__skeleton-image" style="aspect-ratio: 1/1;"></div>
						{% endif %}
						<div class="radius-bundle__skeleton-content">
							<div class="radius-bundle__skeleton-text radius-bundle__skeleton-text--title"></div>
							<div class="radius-bundle__skeleton-text radius-bundle__skeleton-text--price"></div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	{% comment %} Add to Cart Button {% endcomment %}
	{% render 'radius-bundle-add-to-cart',
			bundle_id: bundle_id,
			button_text: button_text
	%}
</div>
