<div class="radius-bundle__actions">
<button type="button" class="radius-bundle__add-to-cart" data-bundle-add-to-cart data-bundle-id="{{ bundle_id }}" disabled>
<span class="radius-bundle__button-loading"><svg aria-hidden="true" focusable="false" class="radius-bundle__spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg"><circle class="radius-bundle__spinner-path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle></svg></span>
<span class="radius-bundle__button-text" data-button-text>{{ button_text | default: 'Add bundle to cart' }}</span>
{%- if layout == 'split_deal' -%}<svg class="radius-bundle__button-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>{%- endif -%}
</button>
</div>